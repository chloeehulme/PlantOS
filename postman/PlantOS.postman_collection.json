    {
      "name": "Plants",
      "item": [
        {
          "name": "Create plant",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Postman Test Plant\",\n  \"species\": \"Test Species\",\n  \"tileX\": 5,\n  \"tileY\": 4\n}"
            },
            "url": "{{baseUrl}}/api/plants"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status code is 201\", function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "var jsonData = pm.response.json();",
                  "pm.test(\"Response contains a plant id\", function () {",
                  "    pm.expect(jsonData.id).to.be.a(\"string\");",
                  "    pm.expect(jsonData.id).to.not.equal(\"\");",
                  "});",
                  "pm.environment.set(\"plantId\", jsonData.id);",
                  "pm.collectionVariables.set(\"plantId\", jsonData.id);"
                ]
              }
            }
          ]
        },
        {
          "name": "Get all plants",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/plants"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "var jsonData = pm.response.json();",
                  "pm.test(\"Response is an array of plants\", function () {",
                  "    pm.expect(jsonData).to.be.an(\"array\");",
                  "    pm.expect(jsonData.length).to.be.greaterThan(0);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Get plant by id",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/plants/{{plantId}}"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "var jsonData = pm.response.json();",
                  "pm.test(\"Returned plant matches the created plant id\", function () {",
                  "    pm.expect(jsonData.id).to.equal(pm.environment.get(\"plantId\"));",
                  "});"
                ]
              }
            }
          ]
